#!/bin/bash

# Copy les fichiers statiques
cp src/index.html public/
cp src/validation.js public/

# Renommer le fichier de sortie
mv public/dist/bundle.js public/script.js

# Mettre en place la configuration Vercel
echo "{
  \"build\": \".\",
  \"scripts\": {
    \"start\": \"npm start\",
    \"prebuild\": \"npm run build\",
    \"postdeploy\": \"echo 'Le déploiement est terminé'\"
  },
  \"proxy\": \"/api\"
}" > vercel.json

# Mettre en place la configuration du script
cp .vercelrc public/.vercelrc
